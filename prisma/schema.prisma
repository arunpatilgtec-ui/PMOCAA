generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  ADMIN
  MANAGER
  PLANNER
  PROJECT_LEAD
  WORKSTREAM_LEAD
  RESOURCE
  LEADERSHIP
}

enum ProjectType {
  TEARDOWN
  OTHER
}

enum ProjectStatus {
  PLANNING
  ACTIVE
  ON_HOLD
  COMPLETED
  CANCELLED
}

enum RequestStatus {
  SUBMITTED
  REVIEW
  APPROVED
  REJECTED
  CONVERTED
}

enum TaskStatus {
  BACKLOG
  PLANNED
  IN_PROGRESS
  REVIEW
  REWORK
  COMPLETED
  CANCELLED
}

enum Priority {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum WorkstreamStatus {
  NOT_STARTED
  IN_PROGRESS
  ON_HOLD
  COMPLETED
}

enum ApprovalStatus {
  PENDING
  APPROVED
  REJECTED
}

enum NotificationType {
  TASK_ASSIGNED
  TASK_UPDATED
  SCHEDULE_CHANGE_PROPOSED
  APPROVAL_REQUIRED
  APPROVAL_COMPLETED
  PROJECT_DELAYED
  MILESTONE_UPCOMING
  RESOURCE_OVERLOADED
}

enum ChangeType {
  TASK_ADDED
  TASK_PRIORITY_CHANGED
  TASK_DURATION_CHANGED
  RESOURCE_OVERLOAD
  RESOURCE_UNAVAILABLE
  PROJECT_PRIORITY_CHANGED
  TASK_DATES_CHANGED
  RESOURCE_REQUESTED
  TIMELINE_CHANGE_REQUESTED
  ANDON_RAISED
}

enum PlanStatus {
  DRAFT
  SUBMITTED
  APPROVED
}

enum StrategicStatus {
  ACTIVE
  COMPLETED
  CANCELLED
}

model User {
  id          String   @id @default(cuid())
  email       String   @unique
  name        String
  password    String
  role        Role     @default(RESOURCE)
  avatarUrl   String?
  capacityPct Int      @default(100)
  department  String?
  title       String?
  isActive           Boolean  @default(true)
  mustChangePassword Boolean  @default(false)
  createdAt          DateTime @default(now())
  updatedAt   DateTime @updatedAt

  ledProjects           Project[]          @relation("ProjectLead")
  plannedProjects       Project[]          @relation("ProjectPlanner")
  ledWorkstreams        Workstream[]       @relation("WorkstreamLead")
  ownedTasks            Task[]             @relation("TaskOwner")
  assignedTasks         Task[]             @relation("TaskAssignedBy")
  approvedTasks         Task[]             @relation("TaskApprovedBy")
  taskHistoryChanges    TaskHistory[]      @relation("TaskHistoryChanger")
  notifications         Notification[]
  approvals             ApprovalRequest[]  @relation("Approver")
  requestedApprovals    ApprovalRequest[]  @relation("Requester")
  submittedRequests     Request[]          @relation("RequestSubmitter")
  assignedRequests      Request[]          @relation("RequestAssignee")
  requestsAssignedByMe  Request[]          @relation("RequestAssignedBy")
  sentNotifications     Notification[]     @relation("NotificationSender")
  scheduledChanges      ScheduleChange[]   @relation("ChangeRequester")
  allocations           ResourceAllocation[]
  documents             Document[]         @relation("DocumentUploader")
  sessions              Session[]
  ledProducts              Product[]          @relation("ProductLead")
  productResources         ProductResource[]  @relation("ProductResourceUser")
  taskOwnerChangesBy       TaskOwnerHistory[] @relation("TaskOwnerChangeBy")
  taskOwnerChangesFrom     TaskOwnerHistory[] @relation("TaskOwnerChangeFrom")
  taskOwnerChangesTo       TaskOwnerHistory[] @relation("TaskOwnerChangeTo")
  productHistoryChanges    ProductHistory[]   @relation("ProductHistoryChanger")
  productHistoryTargeted   ProductHistory[]   @relation("ProductHistoryTarget")
  strategicRequestsSubmitted StrategicRequest[] @relation("StrategicRequestSubmitter")
  strategicTasksAssigned     StrategicTask[]    @relation("StrategicTaskAssignee")

  @@map("users")
}

model Session {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model Request {
  id          String        @id @default(cuid())
  title       String
  description String
  priority    Priority      @default(MEDIUM)
  type        ProjectType
  status      RequestStatus @default(SUBMITTED)
  submitterId    String
  assigneeId     String?
  projectId      String?       @unique
  notes          String?
  estimatedHours Float?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  startDate    DateTime?
  endDate      DateTime?
  isRecurring  Boolean    @default(false)
  hoursPerDay  Float?
  assignedById String?

  submitter  User     @relation("RequestSubmitter", fields: [submitterId], references: [id], onDelete: Cascade)
  assignee   User?    @relation("RequestAssignee", fields: [assigneeId], references: [id], onDelete: SetNull)
  assignedBy User?    @relation("RequestAssignedBy", fields: [assignedById], references: [id], onDelete: SetNull)
  project    Project? @relation(fields: [projectId], references: [id])

  @@map("requests")
}

model Project {
  id          String        @id @default(cuid())
  name        String
  description String?
  type        ProjectType
  status      ProjectStatus @default(PLANNING)
  priority    Priority      @default(MEDIUM)
  startDate   DateTime
  endDate     DateTime
  leadId                String?
  plannerId             String?
  editAccessGranted     Boolean            @default(false)
  planStatus            PlanStatus         @default(DRAFT)
  category              String?
  productType           String?
  projectLinks          String[]
  projectClassification String?
  numberOfProducts      Int?
  createdAt             DateTime           @default(now())
  updatedAt             DateTime           @updatedAt

  lead            User?                @relation("ProjectLead", fields: [leadId], references: [id], onDelete: SetNull)
  planner         User?                @relation("ProjectPlanner", fields: [plannerId], references: [id], onDelete: SetNull)
  request         Request?
  workstreams     Workstream[]
  milestones      Milestone[]
  documents       Document[]
  notifications   Notification[]
  scheduleChanges ScheduleChange[]
  allocations     ResourceAllocation[]
  products        Product[]

  @@map("projects")
}

model Workstream {
  id        String           @id @default(cuid())
  name      String
  projectId String
  leadId    String?
  status    WorkstreamStatus @default(NOT_STARTED)
  order     Int              @default(0)
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt

  project   Project    @relation(fields: [projectId], references: [id], onDelete: Cascade)
  lead      User?      @relation("WorkstreamLead", fields: [leadId], references: [id], onDelete: SetNull)
  tasks     Task[]
  documents Document[]

  @@map("workstreams")
}

model Task {
  id              String     @id @default(cuid())
  name            String
  description     String?
  workstreamId    String
  ownerId         String?
  assignedById    String?
  approvedById    String?
  status          TaskStatus @default(BACKLOG)
  priority        Priority   @default(MEDIUM)
  startDate       DateTime?
  endDate         DateTime?
  effortHours     Float      @default(0)
  estimatedHours  Float      @default(0)
  pctComplete     Int        @default(0)
  actualStartDate DateTime?
  actualEndDate   DateTime?
  order           Int        @default(0)
  dependsOn       String[]
  tags            String[]
  reworkCount     Int        @default(0)
  statusChangedAt DateTime   @default(now())
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt

  workstream      Workstream       @relation(fields: [workstreamId], references: [id], onDelete: Cascade)
  owner           User?            @relation("TaskOwner", fields: [ownerId], references: [id], onDelete: SetNull)
  assignedBy      User?            @relation("TaskAssignedBy", fields: [assignedById], references: [id], onDelete: SetNull)
  approvedBy      User?            @relation("TaskApprovedBy", fields: [approvedById], references: [id], onDelete: SetNull)
  documents       Document[]
  scheduleChanges ScheduleChange[] @relation("AffectedTask")
  notifications   Notification[]
  history         TaskHistory[]
  ownerHistory    TaskOwnerHistory[]

  @@map("tasks")
}

model TaskHistory {
  id              String      @id @default(cuid())
  taskId          String
  fromStatus      TaskStatus?
  toStatus        TaskStatus
  changedAt       DateTime    @default(now())
  durationMinutes Int?
  note            String?
  changedById     String?

  task      Task  @relation(fields: [taskId], references: [id], onDelete: Cascade)
  changedBy User? @relation("TaskHistoryChanger", fields: [changedById], references: [id], onDelete: SetNull)

  @@map("task_history")
}

model Milestone {
  id          String    @id @default(cuid())
  name        String
  projectId   String
  dueDate     DateTime
  completed   Boolean   @default(false)
  completedAt DateTime?
  description String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@map("milestones")
}

model ResourceAllocation {
  id            String   @id @default(cuid())
  userId        String
  projectId     String
  allocationPct Int      @default(0)
  startDate     DateTime
  endDate       DateTime
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([userId, projectId])
  @@map("resource_allocations")
}

model ScheduleChange {
  id              String         @id @default(cuid())
  changeType      ChangeType
  description     String
  requesterId     String
  projectId       String?
  affectedTaskIds String[]
  currentData     Json
  proposedData    Json
  impactSummary   Json
  status          ApprovalStatus @default(PENDING)
  rejectionReason String?
  appliedAt       DateTime?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  requester     User             @relation("ChangeRequester", fields: [requesterId], references: [id], onDelete: Cascade)
  project       Project?         @relation(fields: [projectId], references: [id])
  approval      ApprovalRequest?
  affectedTasks Task[]           @relation("AffectedTask")

  @@map("schedule_changes")
}

model ApprovalRequest {
  id               String         @id @default(cuid())
  scheduleChangeId String         @unique
  requesterId      String
  approverId       String?
  status           ApprovalStatus @default(PENDING)
  comments         String?
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt

  scheduleChange ScheduleChange @relation(fields: [scheduleChangeId], references: [id], onDelete: Cascade)
  requester      User           @relation("Requester", fields: [requesterId], references: [id], onDelete: Cascade)
  approver       User?          @relation("Approver", fields: [approverId], references: [id], onDelete: SetNull)

  @@map("approval_requests")
}

model Notification {
  id        String           @id @default(cuid())
  type      NotificationType
  title     String
  message   String
  userId    String
  senderId  String?
  projectId String?
  taskId    String?
  isRead    Boolean          @default(false)
  actionUrl String?
  metadata  Json?
  createdAt DateTime         @default(now())

  user    User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  sender  User?    @relation("NotificationSender", fields: [senderId], references: [id], onDelete: SetNull)
  project Project? @relation(fields: [projectId], references: [id])
  task    Task?    @relation(fields: [taskId], references: [id])

  @@map("notifications")
}

model Document {
  id           String   @id @default(cuid())
  name         String
  originalName String
  fileType     String
  fileSize     Int
  url          String
  uploaderId   String
  projectId    String?
  workstreamId String?
  taskId       String?
  description  String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  uploader   User        @relation("DocumentUploader", fields: [uploaderId], references: [id], onDelete: Cascade)
  project    Project?    @relation(fields: [projectId], references: [id])
  workstream Workstream? @relation(fields: [workstreamId], references: [id])
  task       Task?       @relation(fields: [taskId], references: [id])

  @@map("documents")
}

model Product {
  id            String   @id @default(cuid())
  projectId     String
  brand         String
  modelNo       String
  leadId        String?
  resourceCount Int?
  order         Int      @default(0)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  project   Project          @relation(fields: [projectId], references: [id], onDelete: Cascade)
  lead      User?            @relation("ProductLead", fields: [leadId], references: [id], onDelete: SetNull)
  resources ProductResource[]
  history   ProductHistory[]

  @@map("products")
}

model ProductHistory {
  id           String   @id @default(cuid())
  productId    String
  action       String
  targetUserId String?
  data         Json     @default("{}")
  changedById  String
  changedAt    DateTime @default(now())

  product    Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  changedBy  User    @relation("ProductHistoryChanger", fields: [changedById], references: [id], onDelete: Cascade)
  targetUser User?   @relation("ProductHistoryTarget", fields: [targetUserId], references: [id], onDelete: SetNull)

  @@map("product_history")
}

model ProductResource {
  id           String   @id @default(cuid())
  productId    String
  userId       String
  subsystems   String[]
  costingTypes String[]
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  user    User    @relation("ProductResourceUser", fields: [userId], references: [id], onDelete: Cascade)

  @@unique([productId, userId])
  @@map("product_resources")
}

model StrategicRequest {
  id          String          @id @default(cuid())
  title       String
  description String?
  startDate   DateTime
  status      StrategicStatus @default(ACTIVE)
  submitterId String
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  submitter User            @relation("StrategicRequestSubmitter", fields: [submitterId], references: [id], onDelete: Cascade)
  tasks     StrategicTask[]

  @@map("strategic_requests")
}

model StrategicTask {
  id                 String   @id @default(cuid())
  title              String
  isRecurring        Boolean  @default(false)
  hoursPerDay        Float?
  estimatedHours     Float?
  startDate          DateTime?
  endDate            DateTime?
  assigneeId         String?
  strategicRequestId String
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  assignee         User?            @relation("StrategicTaskAssignee", fields: [assigneeId], references: [id], onDelete: SetNull)
  strategicRequest StrategicRequest @relation(fields: [strategicRequestId], references: [id], onDelete: Cascade)

  @@map("strategic_tasks")
}

model TaskOwnerHistory {
  id          String   @id @default(cuid())
  taskId      String
  fromOwnerId String?
  toOwnerId   String?
  changedById String
  changedAt   DateTime @default(now())
  note        String?

  task      Task  @relation(fields: [taskId], references: [id], onDelete: Cascade)
  fromOwner User? @relation("TaskOwnerChangeFrom", fields: [fromOwnerId], references: [id], onDelete: SetNull)
  toOwner   User? @relation("TaskOwnerChangeTo", fields: [toOwnerId], references: [id], onDelete: SetNull)
  changedBy User  @relation("TaskOwnerChangeBy", fields: [changedById], references: [id], onDelete: Cascade)

  @@map("task_owner_history")
}
