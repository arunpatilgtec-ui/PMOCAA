generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  ADMIN
  MANAGER
  PLANNER
  PROJECT_LEAD
  WORKSTREAM_LEAD
  RESOURCE
  LEADERSHIP
}

enum ProjectType {
  TEARDOWN
  OTHER
}

enum ProjectStatus {
  PLANNING
  ACTIVE
  ON_HOLD
  COMPLETED
  CANCELLED
}

enum RequestStatus {
  SUBMITTED
  REVIEW
  APPROVED
  REJECTED
  CONVERTED
}

enum TaskStatus {
  BACKLOG
  PLANNED
  IN_PROGRESS
  REVIEW
  COMPLETED
  CANCELLED
}

enum Priority {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum WorkstreamStatus {
  NOT_STARTED
  IN_PROGRESS
  ON_HOLD
  COMPLETED
}

enum ApprovalStatus {
  PENDING
  APPROVED
  REJECTED
}

enum NotificationType {
  TASK_ASSIGNED
  TASK_UPDATED
  SCHEDULE_CHANGE_PROPOSED
  APPROVAL_REQUIRED
  APPROVAL_COMPLETED
  PROJECT_DELAYED
  MILESTONE_UPCOMING
  RESOURCE_OVERLOADED
}

enum ChangeType {
  TASK_ADDED
  TASK_PRIORITY_CHANGED
  TASK_DURATION_CHANGED
  RESOURCE_OVERLOAD
  RESOURCE_UNAVAILABLE
  PROJECT_PRIORITY_CHANGED
  TASK_DATES_CHANGED
}

model User {
  id          String   @id @default(cuid())
  email       String   @unique
  name        String
  password    String
  role        Role     @default(RESOURCE)
  avatarUrl   String?
  capacityPct Int      @default(100)
  department  String?
  title       String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  ledProjects        Project[]          @relation("ProjectLead")
  plannedProjects    Project[]          @relation("ProjectPlanner")
  ledWorkstreams     Workstream[]       @relation("WorkstreamLead")
  ownedTasks         Task[]             @relation("TaskOwner")
  notifications      Notification[]
  approvals          ApprovalRequest[]  @relation("Approver")
  requestedApprovals ApprovalRequest[]  @relation("Requester")
  submittedRequests  Request[]          @relation("RequestSubmitter")
  assignedRequests   Request[]          @relation("RequestAssignee")
  sentNotifications  Notification[]     @relation("NotificationSender")
  scheduledChanges   ScheduleChange[]   @relation("ChangeRequester")
  allocations        ResourceAllocation[]
  documents          Document[]         @relation("DocumentUploader")
  sessions           Session[]

  @@map("users")
}

model Session {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model Request {
  id          String        @id @default(cuid())
  title       String
  description String
  priority    Priority      @default(MEDIUM)
  type        ProjectType
  status      RequestStatus @default(SUBMITTED)
  submitterId    String
  assigneeId     String?
  projectId      String?       @unique
  notes          String?
  estimatedHours Float?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  submitter User     @relation("RequestSubmitter", fields: [submitterId], references: [id])
  assignee  User?    @relation("RequestAssignee", fields: [assigneeId], references: [id])
  project   Project? @relation(fields: [projectId], references: [id])

  @@map("requests")
}

model Project {
  id          String        @id @default(cuid())
  name        String
  description String?
  type        ProjectType
  status      ProjectStatus @default(PLANNING)
  priority    Priority      @default(MEDIUM)
  startDate   DateTime
  endDate     DateTime
  leadId      String?
  plannerId   String?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  lead            User?                @relation("ProjectLead", fields: [leadId], references: [id])
  planner         User?                @relation("ProjectPlanner", fields: [plannerId], references: [id])
  request         Request?
  workstreams     Workstream[]
  milestones      Milestone[]
  documents       Document[]
  notifications   Notification[]
  scheduleChanges ScheduleChange[]
  allocations     ResourceAllocation[]

  @@map("projects")
}

model Workstream {
  id        String           @id @default(cuid())
  name      String
  projectId String
  leadId    String?
  status    WorkstreamStatus @default(NOT_STARTED)
  order     Int              @default(0)
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt

  project   Project    @relation(fields: [projectId], references: [id], onDelete: Cascade)
  lead      User?      @relation("WorkstreamLead", fields: [leadId], references: [id])
  tasks     Task[]
  documents Document[]

  @@map("workstreams")
}

model Task {
  id             String     @id @default(cuid())
  name           String
  description    String?
  workstreamId   String
  ownerId        String?
  status         TaskStatus @default(BACKLOG)
  priority       Priority   @default(MEDIUM)
  startDate      DateTime?
  endDate        DateTime?
  effortHours    Float      @default(0)
  estimatedHours Float      @default(0)
  order          Int        @default(0)
  dependsOn      String[]
  tags           String[]
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt

  workstream      Workstream       @relation(fields: [workstreamId], references: [id], onDelete: Cascade)
  owner           User?            @relation("TaskOwner", fields: [ownerId], references: [id])
  documents       Document[]
  scheduleChanges ScheduleChange[] @relation("AffectedTask")
  notifications   Notification[]

  @@map("tasks")
}

model Milestone {
  id          String    @id @default(cuid())
  name        String
  projectId   String
  dueDate     DateTime
  completed   Boolean   @default(false)
  completedAt DateTime?
  description String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@map("milestones")
}

model ResourceAllocation {
  id            String   @id @default(cuid())
  userId        String
  projectId     String
  allocationPct Int      @default(0)
  startDate     DateTime
  endDate       DateTime
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([userId, projectId])
  @@map("resource_allocations")
}

model ScheduleChange {
  id              String         @id @default(cuid())
  changeType      ChangeType
  description     String
  requesterId     String
  projectId       String?
  affectedTaskIds String[]
  currentData     Json
  proposedData    Json
  impactSummary   Json
  status          ApprovalStatus @default(PENDING)
  rejectionReason String?
  appliedAt       DateTime?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  requester     User             @relation("ChangeRequester", fields: [requesterId], references: [id])
  project       Project?         @relation(fields: [projectId], references: [id])
  approval      ApprovalRequest?
  affectedTasks Task[]           @relation("AffectedTask")

  @@map("schedule_changes")
}

model ApprovalRequest {
  id               String         @id @default(cuid())
  scheduleChangeId String         @unique
  requesterId      String
  approverId       String?
  status           ApprovalStatus @default(PENDING)
  comments         String?
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt

  scheduleChange ScheduleChange @relation(fields: [scheduleChangeId], references: [id], onDelete: Cascade)
  requester      User           @relation("Requester", fields: [requesterId], references: [id])
  approver       User?          @relation("Approver", fields: [approverId], references: [id])

  @@map("approval_requests")
}

model Notification {
  id        String           @id @default(cuid())
  type      NotificationType
  title     String
  message   String
  userId    String
  senderId  String?
  projectId String?
  taskId    String?
  isRead    Boolean          @default(false)
  actionUrl String?
  metadata  Json?
  createdAt DateTime         @default(now())

  user    User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  sender  User?    @relation("NotificationSender", fields: [senderId], references: [id])
  project Project? @relation(fields: [projectId], references: [id])
  task    Task?    @relation(fields: [taskId], references: [id])

  @@map("notifications")
}

model Document {
  id           String   @id @default(cuid())
  name         String
  originalName String
  fileType     String
  fileSize     Int
  url          String
  uploaderId   String
  projectId    String?
  workstreamId String?
  taskId       String?
  description  String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  uploader   User        @relation("DocumentUploader", fields: [uploaderId], references: [id])
  project    Project?    @relation(fields: [projectId], references: [id])
  workstream Workstream? @relation(fields: [workstreamId], references: [id])
  task       Task?       @relation(fields: [taskId], references: [id])

  @@map("documents")
}
